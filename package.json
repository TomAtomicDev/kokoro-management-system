{
  "name": "kokoro-management-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Kokoro Management — operations, inventory, costing and cash-flow system.",
  "engines": {
    "node": ">=24.18"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "check": "pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "build": "pnpm -r --if-present run build",
    "dev:worker": "pnpm --filter @kokoro/worker run dev",
    "dev:web": "pnpm --filter @kokoro/web run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "typescript": "^7.0.2"
  }
}
